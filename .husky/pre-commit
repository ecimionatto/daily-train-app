# Check for potential secrets in staged files
SECRETS_PATTERN='(ANTHROPIC_API_KEY|GOOGLE_CLIENT_ID|password|secret|token|api.key)\s*=\s*['"'"'"][^YOUR_][^'"'"'"]+['"'"'"]'
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|ts|json|env)$' || true)

if [ -n "$STAGED_FILES" ]; then
  if echo "$STAGED_FILES" | xargs grep -lE "$SECRETS_PATTERN" 2>/dev/null; then
    echo "ERROR: Potential secrets detected in staged files above."
    echo "Remove secrets before committing or add the file to .gitignore."
    exit 1
  fi
fi

export PATH="$HOME/.local/share/mise/installs/node/20.19.4/bin:$PATH"
npx lint-staged
