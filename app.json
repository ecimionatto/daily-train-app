{
  "expo": {
    "name": "DailyTrain",
    "slug": "dailytrain",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dailytrain.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSHealthShareUsageDescription": "DailyTrain reads your health data to personalize your training plan.",
        "NSHealthUpdateUsageDescription": "DailyTrain logs workouts to Apple Health."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": false
          }
        }
      ],
      "./plugins/withLlamaRN.js",
      "./plugins/withAppStoreTeam.js"
    ]
  }
}
